{
  "name": "wutai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "wutai:run": "node scripts/wutai_run.mjs",
    "test:evidence": ".venv/bin/python -m unittest discover -s tests/python -v",
    "test:wutai-run": "node --test tests/node/wutai_run.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:providers": "VITE_WUTAI_RESEARCH_ADAPTER=gpt-researcher playwright test tests/e2e/provider-profiles.spec.ts",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-sql": "^2.4.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  }
}
