{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wutai",
  "version": "0.1.0",
  "identifier": "com.haeliotang.wutai",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Wutai",
        "width": 1200,
        "height": 760,
        "minWidth": 860,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
