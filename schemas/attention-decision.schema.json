{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wutai.local/schemas/attention-decision.schema.json",
  "title": "Wutai Attention Decision",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "taskId",
    "generatedAt",
    "decision",
    "packet",
    "attention",
    "accountability",
    "policy",
    "inputs",
    "limitation"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "kind": { "const": "wutai.attention_decision" },
    "taskId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "decision": {
      "enum": [
        "auto_accepted_under_policy",
        "human_attention_required",
        "scoped_ratified",
        "blocked_or_unowned"
      ]
    },
    "summary": { "type": "string" },
    "packet": {
      "type": "object",
      "required": ["packetId", "packetType", "taskId", "producerAdapter", "trustVerdict"],
      "properties": {
        "packetId": { "type": ["string", "null"] },
        "packetType": { "type": ["string", "null"] },
        "taskId": { "type": "string" },
        "producerAdapter": { "type": ["string", "null"] },
        "manifestSha256": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        },
        "trustVerdict": { "enum": ["trusted", "review_required", "blocked"] }
      },
      "additionalProperties": true
    },
    "attention": {
      "type": "object",
      "required": ["required", "reasons"],
      "properties": {
        "required": { "type": "boolean" },
        "reasons": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "severity", "requiredSeat", "message"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "severity": { "enum": ["audit", "review", "blocker"] },
              "requiredSeat": { "type": "string", "minLength": 1 },
              "message": { "type": "string" },
              "evidence": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "accountability": {
      "type": "object",
      "required": [
        "accountableSeatStatus",
        "scopedRatification",
        "humanReviewEvidence"
      ],
      "properties": {
        "accountableSeatStatus": { "enum": ["assigned", "missing"] },
        "accountableSeat": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "scopedRatification": {
          "type": "object",
          "required": ["status", "accepted", "stale"],
          "properties": {
            "status": { "enum": ["accepted", "not_accepted", "not_recorded", "stale"] },
            "accepted": { "type": "boolean" },
            "stale": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "humanReviewEvidence": {
          "enum": ["scoped_ratification", "not_recorded"]
        }
      },
      "additionalProperties": true
    },
    "policy": { "type": "object" },
    "inputs": { "type": "object" },
    "limitation": { "type": "string" }
  },
  "additionalProperties": true
}
