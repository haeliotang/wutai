{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wutai.local/schemas/consumer-attestation-check.schema.json",
  "title": "Wutai Consumer Attestation Check",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "taskId",
    "generatedAt",
    "status",
    "gateDecision",
    "wedgeOutcome",
    "moatOutcome",
    "moatSignal",
    "experimentCell",
    "packet",
    "reviewer",
    "ratification",
    "policy",
    "checks",
    "limitation"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "kind": { "const": "wutai.consumer_attestation_check" },
    "taskId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "status": { "enum": ["passed", "failed"] },
    "gateDecision": { "enum": ["accepted", "not_accepted", "invalid"] },
    "wedgeOutcome": { "enum": ["wedge_win", "wedge_null", "not_recorded"] },
    "moatOutcome": {
      "enum": [
        "refused_with_scope_reason",
        "scoped_ratified",
        "theater_signature",
        "no_action"
      ]
    },
    "moatSignal": { "enum": ["moat_win", "anti_signal", "moat_null"] },
    "experimentCell": {
      "enum": [
        "wedge_win_moat_win",
        "wedge_win_moat_null",
        "wedge_null_moat_win",
        "wedge_null_moat_null",
        "wedge_win_theater",
        "wedge_null_theater",
        "unclassified_theater",
        "unclassified"
      ]
    },
    "summary": { "type": "string" },
    "packet": {
      "type": "object",
      "required": ["packetId", "packetType", "producerAdapter", "manifestSha256", "trustVerdict"],
      "properties": {
        "packetId": { "type": "string", "minLength": 1 },
        "packetType": { "type": "string", "minLength": 1 },
        "producerAdapter": { "type": "string", "minLength": 1 },
        "manifestSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "trustVerdict": { "enum": ["trusted", "review_required", "blocked"] }
      },
      "additionalProperties": true
    },
    "reviewer": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "ratification": {
      "type": "object",
      "required": [
        "decision",
        "declaredScope",
        "excludedScope",
        "scopeReasons",
        "wedgeSignals"
      ],
      "properties": {
        "decision": {
          "enum": ["ratified", "refused", "rejected", "needs_changes", "no_action"]
        },
        "declaredScope": { "type": ["string", "null"] },
        "excludedScope": { "type": ["string", "null"] },
        "scopeReasons": {
          "type": "array",
          "items": { "type": "string" }
        },
        "wedgeSignals": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "policy": {
      "type": "object",
      "required": ["requiredDecision", "disallowedReviewers", "blockedPacketAction"],
      "properties": {
        "requiredDecision": { "const": "scoped_ratified" },
        "disallowedReviewers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockedPacketAction": { "const": "fail" },
        "refusalAction": { "const": "fail_acceptance_but_record_moat_win" },
        "theaterAction": { "const": "fail" }
      },
      "additionalProperties": true
    },
    "antiSignals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "message"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "failed"] },
          "message": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "limitation": { "type": "string" }
  },
  "additionalProperties": true
}
