{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wutai.local/schemas/trust-verdict.schema.json",
  "title": "Wutai Trust Verdict",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "taskId",
    "generatedAt",
    "verdict",
    "checks",
    "metrics",
    "inputs"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "kind": { "const": "wutai.trust_verdict" },
    "taskId": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "verdict": { "enum": ["trusted", "review_required", "blocked"] },
    "summary": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["passed", "review_required", "blocked"] },
          "message": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "metrics": { "type": "object" },
    "inputs": { "type": "object" },
    "policy": { "type": "object" },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
