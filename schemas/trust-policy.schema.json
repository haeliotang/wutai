{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wutai.local/schemas/trust-policy.schema.json",
  "title": "Wutai Trust Policy",
  "type": "object",
  "required": ["schemaVersion", "kind", "policyId"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "kind": { "const": "wutai.trust_policy" },
    "policyId": { "type": "string", "minLength": 1 },
    "sourceLabel": { "type": "string" },
    "requireTrustedProducerForTrusted": { "type": "boolean" },
    "defaultUnsignedAction": { "enum": ["review", "block"] },
    "defaultPolicyWarningAction": { "enum": ["review", "block"] },
    "defaultHighRiskAllowAction": { "enum": ["review", "block"] },
    "defaultMissingRationaleAction": { "enum": ["review", "block"] },
    "rulePolicies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "action": { "enum": ["allow", "review", "block"] },
          "requireRationale": { "type": "boolean" },
          "missingRationaleAction": { "enum": ["review", "block"] },
          "requireTrustedProducer": { "type": "boolean" },
          "requireReviewer": { "type": "boolean" },
          "note": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
