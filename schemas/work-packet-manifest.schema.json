{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wutai.local/schemas/work-packet-manifest.schema.json",
  "title": "Wutai Work Packet Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "packetId",
    "packetType",
    "taskId",
    "generatedAt",
    "producer",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "kind": { "const": "wutai.work_packet_manifest" },
    "packetId": { "type": "string", "minLength": 1 },
    "packetType": { "type": "string", "minLength": 1 },
    "taskId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string" },
    "title": { "type": "string" },
    "status": {
      "enum": [
        "pending",
        "running",
        "completed",
        "completed_with_warnings",
        "failed",
        "cancelled"
      ]
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "producer": {
      "type": "object",
      "required": ["adapter"],
      "properties": {
        "name": { "type": "string" },
        "adapter": { "type": "string", "minLength": 1 },
        "runtime": { "type": "string" }
      },
      "additionalProperties": true
    },
    "audit": { "type": "object" },
    "evidence": { "type": "object" },
    "coverage": { "type": "object" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifactId", "name", "role", "bytes", "sha256"],
        "properties": {
          "artifactId": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "type": { "type": "string" },
          "virtualPath": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "producer": { "type": "object" },
          "createdAt": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
