{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wutai.local/schemas/consumer-attestation.schema.json",
  "title": "Wutai Consumer Attestation",
  "type": "object",
  "required": [
    "schemaVersion",
    "kind",
    "subject",
    "reviewer",
    "decision",
    "reviewedAt",
    "statement"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "kind": { "const": "wutai.consumer_attestation" },
    "subject": {
      "type": "object",
      "required": ["manifestSha256", "packetId", "taskId", "producerAdapter"],
      "properties": {
        "manifestSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "packetId": { "type": "string", "minLength": 1 },
        "taskId": { "type": "string", "minLength": 1 },
        "producerAdapter": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "reviewer": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    },
    "decision": {
      "enum": ["ratified", "refused", "rejected", "needs_changes", "no_action"]
    },
    "declaredScope": {
      "type": "string",
      "description": "Reviewer-written boundary for what is ratified. Required by policy for a ratified decision to count as scoped ratification."
    },
    "excludedScope": {
      "type": "string",
      "description": "Reviewer-written boundary for what is not ratified. Required by policy for a ratified decision to count as scoped ratification."
    },
    "scopeReasons": {
      "type": "array",
      "items": {
        "enum": [
          "intent_drift",
          "empty_seat",
          "unevidenced_claims",
          "scope_boundary",
          "trace_incomplete",
          "other"
        ]
      }
    },
    "refusalReasons": {
      "type": "array",
      "items": {
        "enum": [
          "intent_drift",
          "empty_seat",
          "unevidenced_claims",
          "scope_boundary",
          "trace_incomplete",
          "other"
        ]
      }
    },
    "wedgeSignals": {
      "type": "array",
      "items": {
        "enum": [
          "intent_drift",
          "empty_seat",
          "unevidenced_claims",
          "none"
        ]
      }
    },
    "wedge": {
      "type": "object",
      "properties": {
        "changedReviewBehavior": { "type": "boolean" },
        "signals": {
          "type": "array",
          "items": {
            "enum": [
              "intent_drift",
              "empty_seat",
              "unevidenced_claims",
              "none"
            ]
          }
        },
        "statement": { "type": "string" }
      },
      "additionalProperties": true
    },
    "experiment": {
      "type": "object",
      "properties": {
        "arm": {
          "enum": ["diff_only", "packet", "negative_control", "sham_control"]
        },
        "wizardOfOz": { "type": "boolean" },
        "baselineSignatureDisposition": { "type": "string" },
        "baselineRiskRestatement": { "type": "string" },
        "shamFieldAttributed": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "reviewedAt": { "type": "string", "format": "date-time" },
    "statement": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
